---
import img from '../assets/img.png';
---

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PlagiDec - Deteccion de Plagio e IA para Moodle</title>
  <style>
    /* Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* Fondo */
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #f5f7fa 0%, #e6ecf5 100%) !important;
      color: #003366;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: rgba(255, 255, 255, 0.95); /* tapa el fondo */
      z-index: -1;
    }

    /* Header */
    .header {
      background: linear-gradient(135deg, #003366 0%, #0055A4 100%);
      color: white;
      padding: 80px 20px;
      text-align: center;
    }

    .header h1 {
      font-size: 4rem;
      letter-spacing: 2px;
    }

    .header h1 span {
      color: #f2b705; /* amarillo */
    }

    .subtitle {
      font-size: 1.3rem;
      opacity: 0.9;
    }

    .badge {
      display: inline-block;
      background: rgba(255,255,255,0.1);
      padding: 8px 20px;
      border-radius: 50px;
      margin-top: 20px;
      border: 1px solid rgba(255,255,255,0.3);
    }

    .ubb-footer {
      font-size: 0.8rem;
      margin-top: 15px;
      opacity: 0.7;
    }

    /* Contenedor */
    .container {
      max-width: 1200px;
      margin: auto;
      padding: 60px 20px;
    }

    /* Cards */
    .card {
      background: rgba(255, 255, 255, 0.75); /* blanco transparente */
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: 16px;
      padding: 30px;
      margin-bottom: 40px;
      border-left: 6px solid #0055A4;
      box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .card h2 {
      color: #003366;
      margin-bottom: 20px;
    }

    .card h3 {
      color: #0055A4;
    }

    .card p,
    .card li {
      color: #333;
    }

    /* Grid */
    .grid-3 {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
    }

    .grid-3 {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }

    .grid-4 {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    /* Tool Cards */
    .tool-card {
      display: flex;
      align-items: center;
      gap: 10px;

      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(6px);

      border-radius: 50px; /* 🔥 forma de cápsula */
      padding: 8px 16px;

      border: 1px solid rgba(0, 85, 164, 0.2);
      transition: 0.2s ease;

      width: auto;
      max-width: fit-content;
    }
    .tool-card:hover {
      background: rgba(0, 85, 164, 0.1);
      border-color: #0055A4;
      transform: translateY(-2px);
    }

    .tool-icon {
      font-size: 1.2rem;
      margin: 0;
    }

    .tool-card h4 {
      font-size: 0.9rem;
      margin: 0;
    }

    .tool-card p {
      display: none;
    }

    .tool-tag {
      font-size: 0.6rem;
      padding: 2px 8px;
      margin: 0;
    }

    /* Timeline */
    .timeline {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .timeline-step {
      flex: 1;
      background: #f5f7fa;
      padding: 20px;
      border-radius: 12px;
      text-align: center;
    }

    .timeline-step .number {
      background: #0055A4;
      color: white;
      width: 35px;
      height: 35px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: auto;
      margin-bottom: 10px;
    }

    /* Audience */
    .audience-item {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(6px);
      padding: 20px;
      border-radius: 12px;
      text-align: center;
      border: 1px solid rgba(0, 85, 164, 0.15);
    }

    /* Alert */
    .demo-alert {
      background: #fff8e1;
      border-left: 4px solid #f2b705;
      padding: 15px;
      border-radius: 8px;
      color: #333;
    }

    /* Tabla */
    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 12px;
      overflow: hidden;
    }

    th {
      background: #003366;
      color: white;
    }

    td, th {
      padding: 14px;
    }

    tr:hover {
      background: #f5f7fa;
    }

    /* Botón */
    .btn {
      background: #0055A4;
      color: white;
      padding: 12px 28px;
      border-radius: 40px;
      text-decoration: none;
    }

    .btn:hover {
      background: #003366;
    }

    /* Imagen */
    .content-flex {
      display: flex;
      gap: 30px;
      align-items: center;
    }

    .image-content img {
      max-width: 400px;
      border-radius: 12px;
    }

    /* Logo */
    .logo {
      width: 80px;
      margin-bottom: 15px;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .content-flex {
        flex-direction: column;
      }

      .header h1 {
        font-size: 2.5rem;
      }
    }

    .img-separador {
      display: block;
      margin: 25px auto 0 auto; /* centra */
      width: 100%;              /* ocupa todo el ancho */
      max-width: 900px;        /* no crece demasiado */
      height: auto;            /* mantiene proporción */
      opacity: 0.9;            /* leve transparencia */
    }
  </style>
</head>
<body>

<div class="header">
  <h1>PLAGI<span>DEC</span></h1>
  <div class="subtitle">Deteccion de Plagio y Contenido Generado por IA</div>
  <div class="badge">Modulo nativo para Moodle | Universidad del Bio-Bio</div>
  <div class="ubb-footer">Universidad del Bio-Bio · Concepcion, Chile · Edificio ADPT · UGCM</div>
</div>

<div class="card">
  <div class="content-flex">

    <!-- Texto -->
    <div class="text-content">
      <h2>Que es PlagiDec</h2>
      <p><strong>PlagiDec</strong> (Plagio + Deteccion) es un modulo integrable a la plataforma <strong>Moodle</strong> que permite a los docentes de la Universidad del Bio-Bio detectar de manera automatizada:</p>
      <ul>
        <li>Casos de <strong>plagio textual</strong> (copia literal o parafrasis)</li>
        <li><strong>Contenido generado por Inteligencia Artificial</strong> (ChatGPT, Gemini, Copilot, entre otros)</li>
      </ul>
      <p>Todo esto sin salir de Moodle, sin costos de suscripcion y manteniendo los datos dentro de la universidad.</p>
    </div>

    <!-- Imagen -->
    <div class="image-content">
      <img src="https://st.depositphotos.com/1004713/3188/i/950/depositphotos_31885447-stock-photo-college-student-trying-to-copy.jpg" alt="Plagio IA">
    </div>

  </div>
</div>

  <!-- Para quien esta definido -->
  <div class="card">
    <h2>Para quien esta definido</h2>
    <div class="grid-4">
      <div class="audience-item">
        <div class="audience-icon">Profesores</div>
        <h3>Docentes UBB</h3>
        <p>Revision automatica, ahorro de tiempo y evaluacion objetiva</p>
      </div>
      <div class="audience-item">
        <div class="audience-icon">UGCM / ADPT</div>
        <h3>Unidad UGCM / ADPT</h3>
        <p>Herramienta institucional sin dependencia externa</p>
      </div>
      <div class="audience-item">
        <div class="audience-icon">Comites</div>
        <h3>Comites Academicos</h3>
        <p>Evidencia tecnica para casos de deshonestidad academica</p>
      </div>
    </div>
  </div>

  <!-- Limitaciones -->
  <div class="card">
    <ul>
      <li>Solo soportara formatos de archivos usados por la intitución ( Doc, Docx, PDF, etc.)</li>
      <li>Modelo optimizado para español</li>
      <li>procesamiento y respuesta a travez de hardware institucional</li>
    </ul>
  </div>

<div class="card">
  <h2>Para que va a ser usado</h2>

  <div class="timeline">
    <div class="timeline-step">
      <div class="number">1</div>
      <strong>Asignacion</strong>
      <p>Docente publica actividad en Moodle</p>
    </div>

    <div class="timeline-step">
      <div class="number">2</div>
      <strong>Entrega</strong>
      <p>Estudiante sube su trabajo</p>
    </div>

    <div class="timeline-step">
      <div class="number">3</div>
      <strong>Analisis</strong>
      <p>PlagiDec procesa automaticamente</p>
    </div>

    <div class="timeline-step">
      <div class="number">4</div>
      <strong>Reporte</strong>
      <p>Visualizacion de porcentajes y probabilidad</p>
    </div>

    <div class="timeline-step">
      <div class="number">5</div>
      <strong>Evaluacion</strong>
      <p>Calificacion con respaldo objetivo</p>
    </div>
  </div>
</div>

  <!-- Herramientas y tecnologias -->
  <div class="card">
    <h2>Herramientas y Tecnologias</h2>

    <h3>Backend y Procesamiento</h3>
    <div class="grid-3">
      <div class="tool-card">
        <div class="tool-icon">Python</div>
        <h4>Python</h4>
        <p>Lenguaje principal para motores de deteccion</p>
        <span class="tool-tag">Core Engine</span>
      </div>
      <div class="tool-card">
        <div class="tool-icon">PyTorch</div>
        <h4>PyTorch</h4>
        <p>Framework para modelos de deep learning</p>
        <span class="tool-tag">IA / ML</span>
      </div>
      <div class="tool-card">
        <div class="tool-icon">HuggingFace</div>
        <h4>Hugging Face</h4>
        <p>Modelos pre-entrenados (RoBERTa, Sentence-BERT)</p>
        <span class="tool-tag">NLP</span>
      </div>
    </div>

    <h3>Algoritmos de Deteccion de Plagio</h3>
    <div class="grid-3">
      <div class="tool-card">
        <div class="tool-icon">Shingling</div>
        <h4>Shingling (Fingerprinting)</h4>
        <p>Comparacion de fragmentos contra base de datos interna</p>
        <span class="tool-tag">Similitud textual</span>
      </div>
      <div class="tool-card">
        <div class="tool-icon">Sentence-BERT</div>
        <h4>Similitud Coseno + SBERT</h4>
        <p>Deteccion de parafrasis mediante embeddings semanticos</p>
        <span class="tool-tag">Embeddings</span>
      </div>
      <div class="tool-card">
        <div class="tool-icon">Google API</div>
        <h4>Google Custom Search API</h4>
        <p>Consulta a fuentes externas (primeras paginas)</p>
        <span class="tool-tag">Web Check</span>
      </div>
    </div>

    <h3>Deteccion de Contenido IA</h3>
    <div class="grid-3">
      <div class="tool-card">
        <div class="tool-icon">RoBERTa</div>
        <h4>RoBERTa fine-tuned</h4>
        <p>Modelo entrenado con datasets HC3 y GPT-Soap</p>
        <span class="tool-tag">Clasificacion binaria</span>
      </div>
      <div class="tool-card">
        <div class="tool-icon">HC3</div>
        <h4>HC3 Dataset</h4>
        <p>Human & ChatGPT Comparison Corpus</p>
        <span class="tool-tag">Dataset</span>
      </div>
    </div>

    <h3>Integracion con Moodle</h3>
    <div class="grid-3">
      <div class="tool-card">
        <div class="tool-icon">PHP</div>
        <h4>PHP</h4>
        <p>Desarrollo del plugin para Moodle</p>
        <span class="tool-tag">Plugin Core</span>
      </div>
      <div class="tool-card">
        <div class="tool-icon">JavaScript</div>
        <h4>JavaScript</h4>
        <p>Interfaz interactiva y reportes visuales</p>
        <span class="tool-tag">Frontend</span>
      </div>
      <div class="tool-card">
        <div class="tool-icon">DB UBB</div>
        <h4>Base de datos institucional</h4>
        <p>Almacenamiento anonimizado de entregas previas</p>
        <span class="tool-tag">Comparacion historica</span>
      </div>
    </div>
  </div>

  <!-- Flujo de funcionamiento -->
  <div class="card">
    <h2>Funcionamiento</h2>
    <div class="timeline">
      <div class="timeline-step"><div class="number">1</div><strong>Recepcion</strong><p>Archivo desde Moodle</p></div>
      <div class="timeline-step"><div class="number">2</div><strong>Preprocesamiento</strong><p>Limpieza y tokenizacion</p></div>
      <div class="timeline-step"><div class="number">3</div><strong>Analisis Similitud</strong><p>Shingling + Embeddings</p></div>
      <div class="timeline-step"><div class="number">4</div><strong>Deteccion IA</strong><p>Modelo RoBERTa</p></div>
      <div class="timeline-step"><div class="number">5</div><strong>Reporte</strong><p>Visualizacion en interfaz</p></div>
    </div>
    <img src={img.src} alt="decoracion" class="img-separador">
  </div>
</div>
<script>
  // Intersection Observer para animacion de tarjetas (sin errores de estilo)
  const cards = document.querySelectorAll('.card');
  if (cards.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    cards.forEach(card => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(30px)';
      card.style.transition = 'all 0.5s ease-out';
      observer.observe(card);
    });
  }


</script>
</body>
</html>


